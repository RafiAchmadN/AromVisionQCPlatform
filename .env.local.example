# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Gateway (internal microservices base URL — all traffic routed through here)
API_GATEWAY_URL=http://localhost:4000

# SMTP (for email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=AromAI QC <noreply@example.com>

# Internal service token (used by YOLO service to post frame data)
INTERNAL_SERVICE_TOKEN=your-internal-service-secret
